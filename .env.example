# Runtime
APP_ENV=local
PROCESS_ROLE=api
LOG_LEVEL=INFO
ADMIN_API_TOKEN=change-me-local-admin-token

# Database
DATABASE_URL=postgresql+psycopg://quantagora:quantagora@postgres:5432/quantagora

# Broker: Korea Investment Securities Open API
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_ACCOUNT_NO=
KIS_ACCOUNT_PRODUCT_CODE=
# Optional override. Leave blank to derive from KIS_MODE.
KIS_BASE_URL=
KIS_LIVE_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_PAPER_BASE_URL=https://openapivts.koreainvestment.com:29443
KIS_MODE=paper
KIS_TIMEOUT_SECONDS=10
KIS_RATE_LIMIT_PER_SECOND=5

# Market data and US regular-session guard
MARKET_QUOTE_STALE_SECONDS=900
MARKET_DAILY_CANDLE_LOOKBACK_DAYS=365
MARKET_DATA_DEFAULT_SYMBOLS=SPY,QQQ,TQQQ,SQQQ
# Comma-separated ISO dates for emergency closures or broker-specific overrides.
MARKET_EXTRA_CLOSED_DATES=
MARKET_EXTRA_EARLY_CLOSE_DATES=

# Universe engine
UNIVERSE_SEED_SYMBOLS=SPY,QQQ,DIA,IWM,VTI,TLT,GLD,XLK,XLF,XLV,XLE,XLI,XLY,XLP,SMH,TQQQ,SQQQ,SOXL,SOXS,UPRO,SPXU,AAPL,MSFT,NVDA,AMZN,GOOGL,META,TSLA
UNIVERSE_MAX_MEMBERS=30
UNIVERSE_MIN_PRICE_USD=5
UNIVERSE_MAX_PRICE_USD=1000
UNIVERSE_MIN_AVG_DOLLAR_VOLUME_USD=50000000
UNIVERSE_MAX_BID_ASK_SPREAD_BPS=50
UNIVERSE_LIQUIDITY_LOOKBACK_DAYS=60
UNIVERSE_LEVERAGED_INVERSE_WHITELIST=TQQQ,SQQQ,SOXL,SOXS,UPRO,SPXU

# Signal engine
SIGNAL_LOOKBACK_DAYS=260
SIGNAL_MIN_HISTORY_DAYS=200
SIGNAL_EXPIRY_DAYS=5
SIGNAL_PULLBACK_LOOKBACK_DAYS=5
SIGNAL_SCAN_HOUR_UTC=21
SIGNAL_SCAN_MINUTE_UTC=15
# Use PROCESS_ROLE=scheduler for a dedicated single scheduler process in production.
SIGNAL_SCHEDULER_ENABLED=false
SIGNAL_VOLATILITY_MAX_ANNUALIZED=0.65
SIGNAL_LEVERAGED_VOLATILITY_MAX_ANNUALIZED=1.25

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_IDS=
TELEGRAM_WEBHOOK_SECRET=

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENROUTER_API_KEY=
LLM_MODEL=gpt-5-mini
LLM_BASE_URL=
LLM_TIMEOUT_SECONDS=20
OPENROUTER_SITE_URL=
OPENROUTER_APP_NAME=QuantAgora

# Frontend
VITE_API_BASE_URL=http://localhost:8000
